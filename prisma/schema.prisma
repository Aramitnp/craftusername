// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Platform {
  id                String  @id @default(uuid())
  name              String
  slug              String  @unique
  logo              String
  profileUrlPattern String
  isActive          Boolean @default(true)
  sortOrder         Int     @default(0)
  checkMethod       String  @default("GET")
  errorType         String  @default("status_code")
  errorMsg          String?
  seoTitleOverride  String?
  seoDescOverride   String?
  contentTitle      String?
  contentBody       String?
  heroSubtitle      String?
  
  faqs              PlatformFAQ[]
  relatedBlogPosts  PlatformRelatedBlogPost[]
}

model SiteConfig {
  id        String   @id @default("global")
  content   String   // JSON string
  seo       String   // JSON string
  updatedAt DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  url       String
  publicId  String   @unique
  createdAt DateTime @default(now())
}

model Page {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  seoTitle         String?
  seoDescription   String?
  openGraphTitle   String?
  openGraphDesc    String?
  openGraphImage   String?
  featuredImage    String?
  featuredImageAlt String?
  content          String?
  status           String   @default("DRAFT")
  robots           String   @default("index, follow")
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BlogPost {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  seoTitle         String?
  seoDescription   String?
  openGraphTitle   String?
  openGraphDesc    String?
  openGraphImage   String?
  featuredImage    String?
  featuredImageAlt String?
  categoryId       String?
  category         BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags             BlogTag[]
  author           String?
  content          String?
  status           String   @default("DRAFT")
  robots           String   @default("index, follow")
  publishedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  relatedPlatforms PlatformRelatedBlogPost[]
}

model PlatformFAQ {
  id         String   @id @default(uuid())
  platformId String
  question   String
  answer     String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@index([platformId])
}

model PlatformRelatedBlogPost {
  id         String   @id @default(uuid())
  platformId String
  blogPostId String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([platformId, blogPostId])
  @@index([platformId])
  @@index([blogPostId])
}

model BlogCategory {
  id               String     @id @default(uuid())
  name             String
  slug             String     @unique
  description      String?
  seoTitle         String?
  seoDescription   String?
  featuredImage    String?
  featuredImageAlt String?
  status           String     @default("ACTIVE")
  robots           String     @default("index, follow")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  
  posts            BlogPost[]
}

model BlogTag {
  id               String     @id @default(uuid())
  name             String
  slug             String     @unique
  description      String?
  seoTitle         String?
  seoDescription   String?
  featuredImage    String?
  featuredImageAlt String?
  status           String     @default("ACTIVE")
  robots           String     @default("noindex, follow")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  
  posts            BlogPost[]
}

model Redirect {
  id               String   @id @default(uuid())
  source           String   @unique
  destination      String
  permanent        Boolean  @default(true)
  createdAt        DateTime @default(now())
}
